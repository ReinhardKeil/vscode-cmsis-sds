{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["\"", "\""],
        ["'", "'"]
    ],
    "folding": {
        "offSide": true
    },
    "indentationRules": {
        "increaseIndentPattern": "^\\s*.*:\\s*$",
        "decreaseIndentPattern": "^\\s*\\}\\s*$"
    }
}
