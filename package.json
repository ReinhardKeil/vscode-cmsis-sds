{
    "name": "cmsis-sds",
    "displayName": "Arm SDS",
    "description": "Record and manage synchronous data streams for ML/DSP development using the Arm SDS-Framework",
    "version": "0.9.0",
    "publisher": "arm",
    "license": "Apache-2.0",
    "engines": {
        "node": "^22.22.0",
        "npm": "^10.0.0",
        "vscode": "^1.118.0"
    },
    "categories": [
        "Visualization",
        "Other"
    ],
    "keywords": [
        "arm",
        "sds",
        "sensor",
        "iot",
        "cmsis",
        "data stream",
        "waveform"
    ],
    "icon": "media/arm.png",
    "activationEvents": [
        "onLanguage:yaml",
        "workspaceContains:**/*.sds",
        "workspaceContains:**/*.sds.yml",
        "workspaceContains:**/*.sdsio.yml"
    ],
    "qna": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds/issues/new",
    "bugs": {
        "url": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds.git"
    },
    "main": "./out/src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "arm-sds.openViewer",
                "title": "Open SDS Viewer",
                "category": "SDS Tools",
                "icon": "$(graph-line)"
            },
            {
                "command": "arm-sds.openMediaViewer",
                "title": "Open Media Viewer",
                "category": "SDS Tools",
                "icon": "$(preview)"
            },
            {
                "command": "arm-sds.sdsCheck",
                "title": "Check Data File",
                "category": "SDS Tools",
                "icon": "$(preview)"
            },
            {
                "command": "arm-sds.exportCsv",
                "title": "Export SDS to CSV",
                "category": "SDS Tools",
                "icon": "$(export)"
            },
            {
                "command": "arm-sds.refreshExplorer",
                "title": "Refresh",
                "category": "SDS Tools",
                "icon": "$(refresh)"
            },
            {
                "command": "arm-sds.initWorkspace",
                "title": "Initialize SDS Workspace",
                "category": "SDS Tools",
                "icon": "$(folder-opened)"
            },
            {
                "command": "arm-sds.deleteFile",
                "title": "Delete SDS File",
                "category": "SDS Tools",
                "icon": "$(trash)"
            },
            {
                "command": "arm-sds.createMetadata",
                "title": "Create / Edit Metadata (YAML)",
                "category": "SDS Tools",
                "icon": "$(file-add)"
            },
            {
                "command": "arm-sds.showDiagnostics",
                "title": "Show Diagnostics",
                "category": "SDS Tools",
                "icon": "$(output)"
            },
            {
                "command": "arm-sds.clearDiagnostics",
                "title": "Clear Diagnostics Log",
                "category": "SDS Tools",
                "icon": "$(clear-all)"
            },
            {
                "command": "arm-sds.quickOpen",
                "title": "Quick Open SDS File",
                "category": "SDS Tools",
                "icon": "$(zap)"
            },
            {
                "command": "arm-sds.sdsinterface.play",
                "title": "Start Playback",
                "category": "SDS Tools",
                "icon": "$(play)",
                "enablement": "arm-sds.sdsio.canPlay"
            },
            {
                "command": "arm-sds.sdsinterface.record",
                "title": "Start Recording",
                "category": "SDS Tools",
                "icon": "$(record)",
                "enablement": "arm-sds.sdsio.canRecord"
            },
            {
                "command": "arm-sds.sdsinterface.stop",
                "title": "Stop IO (Playback/Recording)",
                "category": "SDS Tools",
                "icon": "$(debug-stop)",
                "enablement": "arm-sds.sdsio.canStop"
            },
            {
                "command": "arm-sds.sdsinterface.connect",
                "title": "Connect SDSIO Monitor",
                "category": "SDS Tools",
                "icon": "$(plug)",
                "enablement": "arm-sds.sdsio.canConnect"
            },
            {
                "command": "arm-sds.sdsinterface.disconnect",
                "title": "Disconnect SDSIO Monitor",
                "category": "SDS Tools",
                "icon": "$(debug-disconnect)",
                "enablement": "arm-sds.sdsio.canDisconnect"
            },
            {
                "command": "arm-sds.sds.newConfig",
                "title": "Create Configuration…",
                "category": "SDS",
                "icon": "$(add)"
            },
            {
                "command": "arm-sds.sds.openConfig",
                "title": "Open SDS Configuration",
                "category": "SDS",
                "icon": "$(folder-opened)"
            },
            {
                "command": "arm-sds.sds.selectConfig",
                "title": "Open Configuration in Workspace…",
                "category": "SDS"
            },
            {
                "command": "arm-sds.sds.closeConfig",
                "title": "Close Configuration",
                "category": "SDS"
            },
            {
                "command": "arm-sds.sds.editConfig",
                "title": "Open sdsio.yml file",
                "category": "SDS",
                "icon": "$(go-to-file)"
            },
            {
                "command": "arm-sds.openGroupMetadata",
                "title": "Open Stream Metadata",
                "category": "SDS Tools",
                "icon": "$(edit)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "arm-sds-explorer",
                    "title": "Arm SDS",
                    "icon": "media/icons/sds-icon.svg"
                }
            ]
        },
        "views": {
            "arm-sds-explorer": [
                {
                    "id": "sdsExplorer",
                    "name": "Files",
                    "icon": "media/icons/sds-icon.svg",
                    "contextualTitle": "SDS"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "sdsExplorer",
                "contents": "No SDS configuration selected.\n[New SDS Configuration](command:arm-sds.sds.newConfig)\n[Open SDS Configuration](command:arm-sds.sds.openConfig)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "arm-sds.sdsinterface.play",
                    "when": "view == sdsExplorer && arm-sds.sdsio.canPlay",
                    "group": "navigation@0"
                },
                {
                    "command": "arm-sds.sdsinterface.record",
                    "when": "view == sdsExplorer && arm-sds.sdsio.canRecord",
                    "group": "navigation@1"
                },
                {
                    "command": "arm-sds.sdsinterface.stop",
                    "when": "view == sdsExplorer && arm-sds.sdsio.canStop",
                    "group": "navigation@2"
                },
                {
                    "command": "arm-sds.sdsinterface.connect",
                    "when": "view == sdsExplorer && arm-sds.sdsio.canConnect",
                    "group": "navigation@3"
                },
                {
                    "command": "arm-sds.sdsinterface.disconnect",
                    "when": "view == sdsExplorer && arm-sds.sdsio.canDisconnect",
                    "group": "navigation@3"
                },
                {
                    "command": "arm-sds.sds.editConfig",
                    "when": "view == sdsExplorer && arm-sds.sdsio.hasConfig",
                    "group": "navigation@4"
                },
                {
                    "command": "arm-sds.sds.selectConfig",
                    "when": "view == sdsExplorer",
                    "group": "1_config1@0"
                },
                {
                    "command": "arm-sds.sds.newConfig",
                    "when": "view == sdsExplorer",
                    "group": "1_config1@1"
                },
                {
                    "command": "arm-sds.sds.closeConfig",
                    "when": "view == sdsExplorer",
                    "group": "1_config1@2"
                },
                {
                    "command": "arm-sds.refreshExplorer",
                    "when": "view == sdsExplorer",
                    "group": "1_config2@0"
                }
            ],
            "view/item/context": [
                {
                    "command": "arm-sds.openViewer",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "inline"
                },
                {
                    "command": "arm-sds.openMediaViewer",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "1_view"
                },
                {
                    "command": "arm-sds.createMetadata",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "1_view"
                },
                {
                    "command": "arm-sds.sdsCheck",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "1_view"
                },
                {
                    "command": "arm-sds.exportCsv",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "2_export"
                },
                {
                    "command": "arm-sds.deleteFile",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "3_danger"
                },
                {
                    "command": "arm-sds.openGroupMetadata",
                    "when": "view == sdsExplorer && viewItem == groupMetadata",
                    "group": "inline"
                }
            ],
            "explorer/context": [
                {
                    "command": "arm-sds.openViewer",
                    "when": "resourceExtname == .sds",
                    "group": "navigation"
                },
                {
                    "command": "arm-sds.openMediaViewer",
                    "when": "resourceExtname == .sds",
                    "group": "navigation"
                },
                {
                    "command": "arm-sds.createMetadata",
                    "when": "resourceExtname == .sds",
                    "group": "navigation"
                }
            ],
            "commandPalette": [
                {
                    "command": "arm-sds.deleteFile",
                    "when": "false"
                }
            ]
        },
        "json.schemas": [
            {
                "fileMatch": ["**/*.sds.yml", "**/*.sds.yaml"],
                "url": "./schema/sds.schema.json"
            },
            {
                "fileMatch": ["**/*.sdsio.yml", "**/*.sdsio.yaml"],
                "url": "./schema/sdsio.schema.json"
            }
        ],
        "configuration": {
            "title": "SDS",
            "properties": {
                "arm-sds.viewer.defaultZoomLevel": {
                    "type": "number",
                    "default": 1,
                    "description": "Default zoom level for the waveform viewer"
                },
                "arm-sds.viewer.colorScheme": {
                    "type": "string",
                    "default": "auto",
                    "enum": [
                        "auto",
                        "dark",
                        "light"
                    ],
                    "description": "Color scheme for the waveform viewer"
                },
                "arm-sds.viewer.decimationPreset": {
                    "type": "string",
                    "default": "accuracy",
                    "enum": [
                        "accuracy",
                        "performance"
                    ],
                    "description": "Default decimation preset for SDS charts (accuracy keeps more points, performance uses fewer points)."
                },
                "cmsis-sds.sdsio.configFile": {
                    "type": "string",
                    "default": "",
                    "description": "Relative path to the active .sdsio.yml configuration file",
                    "scope": "resource"
                }
            }
        },
        "keybindings": [
            {
                "command": "arm-sds.openViewer",
                "key": "ctrl+shift+v",
                "mac": "cmd+shift+v",
                "when": "resourceExtname == .sds"
            },
            {
                "command": "arm-sds.quickOpen",
                "key": "ctrl+shift+s",
                "mac": "cmd+shift+s",
                "when": "workbenchState != empty"
            }
        ],
        "icons": {
            "arm-sds-sds-icon": {
                "description": "CMSIS SDS — sds-icon",
                "default": {
                    "fontPath": "./media/cmsissds.ttf",
                    "fontCharacter": "\\E000"
                }
            }
        }
    },
    "scripts": {
        "all": "npm install && npm run download-tools && npm run test",
        "build:icons": "fantasticon && node scripts/generate-icon-contributes.js",
        "compile": "npm-run-all compile:extension compile:webviews",
        "compile:scripts": "tsc -p scripts --outDir out/scripts",
        "compile:extension": "tsc -p .",
        "compile:webviews": "node esbuild.js",
        "watch": "run-p watch:extension watch:webviews",
        "watch:extension": "tsc -watch -p .",
        "watch:webviews": "node esbuild.js --watch",
        "prebuild": "npm run build:icons",
        "build": "node esbuild.js --production",
        "lint:md": "markdownlint **/*.md -c ./.github/markdownlint.jsonc -i ./node_modules -i ./dist -i ./coverage -i ./out -i ./tools -i ./test-data -i ./src/e2e-tests/data -i CHANGELOG.md",
        "download-tools": "npm run compile:scripts && tsx scripts/download-tools.ts sdsio",
        "download-tools:nightly": "npm run compile:scripts && tsx scripts/download-tools.ts sdsioNightly",
        "package": "npm run build && tsx scripts/package.ts",
        "test": "npm-run-all test:unit test:integration test:e2e",
        "test:unit": "vitest run --config vitest.config.ts",
        "test:integration": "vitest run --config vitest.config.ts",
        "pretest:e2e": "npm run compile:webviews",
        "test:e2e": "npx playwright test --config=playwright.config.ts",
        "copyright:check": "tsx scripts/copyright-manager.ts --mode=check --include=src/**/*.ts,scripts/**/*.ts --exclude=**/node_modules/**,coverage/**,dist/**,tools/**,out/**",
        "copyright:fix": "tsx scripts/copyright-manager.ts --mode=fix --include=src/**/*.ts,scripts/**/*.ts --exclude=**/node_modules/**,coverage/**,dist/**,tools/**,out/**",
        "tpip:report": "tsx scripts/tpip-reporter --header docs/tpip-header.md docs/third-party-licenses.json TPIP.md",
        "tpip:update": "tsx scripts/update-tpip docs/third-party-licenses.json",
        "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.{ts,js}\""
    },
    "devDependencies": {
        "@open-cmsis-pack/vsce-helper": "^0.3.0",
        "@playwright/test": "^1.60.0",
        "@twbs/fantasticon": "^3.1.0",
        "@types/fs-extra": "^11.0.4",
        "@types/minimist": "^1.2.5",
        "@types/node": "^22.19.19",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@types/semver": "^7.7.1",
        "@types/vscode": "^1.118.0",
        "@types/yargs": "^17.0.35",
        "@typescript-eslint/eslint-plugin": "8.56.1",
        "@typescript-eslint/parser": "8.56.1",
        "@vscode/vsce": "^3.9.1",
        "esbuild": "^0.28.1",
        "eslint": "^10.0.2",
        "fs-extra": "^11.3.3",
        "glob": "^13.0.6",
        "markdownlint-cli": "^0.48.0",
        "npm-run-all": "^4.1.5",
        "semver": "^7.8.0",
        "tsx": "^4.22.4",
        "type-fest": "^5.6.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.6"
    },
    "dependencies": {
        "@ant-design/charts": "^2.2.21",
        "@ant-design/icons": "^6.2.3",
        "antd": "^6.3.4",
        "debug": "^4.4.3",
        "ms": "^2.1.3",
        "node-gyp-build": "^4.8.4",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "yargs": "^18.0.0"
    },
    "overrides": {
        "tar@>=6.1.2": "^7.5.11",
        "@tootallnate/once": "3.0.1",
        "@vscode/vsce": {
            "cheerio": "1.0.0-rc.12"
        },
        "markdownlint-cli": {
            "minimatch": "^10.2.4"
        },
        "rimraf": "^4.0.0",
        "prebuild-install": "^8.0.0"
    },
    "cmsis": {
        "sdsio": "ARM-software/SDS-Framework@3.0.0",
        "sdsioNightly": "ARM-software/SDS-Framework@build_sdsio-server"
    }
}
