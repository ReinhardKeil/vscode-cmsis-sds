{
  "name": "sds-tools",
  "displayName": "SDS Tools",
  "description": "VS Code extension for CMSIS Synchronous Data Stream (SDS) — record, view, and export sensor data",
  "version": "0.8.0",
  "publisher": "open-cmsis",
  "license": "Apache-2.0",
  "engines": {
    "node": "^22.22.0",
    "npm": "^10.0.0",
    "vscode": "^1.108.1"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "arm",
    "sds",
    "sensor",
    "iot",
    "cmsis",
    "data stream",
    "waveform"
  ],
  "icon": "media/icon.png",
  "activationEvents": [
    "onLanguage:yaml",
    "workspaceContains:**/*.sds",
    "workspaceContains:**/*.sds.yml",
    "onCommand:arm-sds.newRecording",
    "onCommand:arm-sds.openRecorder",
    "onCommand:arm-sds.initWorkspace",
    "onCommand:arm-sds.showDiagnostics"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds.git"
 },
  "main": "./out/src/extension.js",
  "contributes": {
    "commands": [
      { "command": "arm-sds.openViewer", "title": "Open SDS Viewer", "category": "SDS Tools", "icon": "$(graph-line)" },
      { "command": "arm-sds.openRecorder", "title": "Open SDS Recorder", "category": "SDS Tools", "icon": "$(record)" },
      { "command": "arm-sds.openMediaViewer", "title": "Open Media Viewer", "category": "SDS Tools", "icon": "$(preview)" },
      { "command": "arm-sds.exportCsv", "title": "Export SDS to CSV", "category": "SDS Tools", "icon": "$(export)" },
      { "command": "arm-sds.refreshExplorer", "title": "Refresh SDS Explorer", "category": "SDS Tools", "icon": "$(refresh)" },
      { "command": "arm-sds.newRecording", "title": "New SDS Recording", "category": "SDS Tools", "icon": "$(add)" },
      { "command": "arm-sds.initWorkspace", "title": "Initialize SDS Workspace", "category": "SDS Tools", "icon": "$(folder-opened)" },
      { "command": "arm-sds.deleteFile", "title": "Delete SDS File", "category": "SDS Tools", "icon": "$(trash)" },
      { "command": "arm-sds.createMetadata", "title": "Create / Edit Metadata (YAML)", "category": "SDS Tools", "icon": "$(file-add)" },
      { "command": "arm-sds.showDiagnostics", "title": "Show Diagnostics", "category": "SDS Tools", "icon": "$(output)" },
      { "command": "arm-sds.clearDiagnostics", "title": "Clear Diagnostics Log", "category": "SDS Tools", "icon": "$(clear-all)" },
      { "command": "arm-sds.quickOpen", "title": "Quick Open SDS File", "category": "SDS Tools", "icon": "$(zap)" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "arm-sds-explorer", "title": "SDS Tools", "icon": "media/sds-icon.svg" }
      ]
    },
    "views": {
      "arm-sds-explorer": [
        { "id": "sdsExplorer", "name": "SDS Files", "icon": "$(graph-line)", "contextualTitle": "SDS Explorer" }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sdsExplorer",
        "contents": "No SDS files found in the workspace.\n[Initialize SDS Workspace](command:arm-sds.initWorkspace)\n[Open SDS Recorder](command:arm-sds.openRecorder)"
      }
    ],
    "menus": {
      "view/title": [
        { "command": "arm-sds.refreshExplorer", "when": "view == sdsExplorer", "group": "navigation" },
        { "command": "arm-sds.newRecording", "when": "view == sdsExplorer", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "arm-sds.openViewer", "when": "view == sdsExplorer && viewItem == sdsFile", "group": "inline" },
        { "command": "arm-sds.openMediaViewer", "when": "view == sdsExplorer && viewItem == sdsFile", "group": "1_view" },
        { "command": "arm-sds.createMetadata", "when": "view == sdsExplorer && viewItem == sdsFile", "group": "1_view" },
        { "command": "arm-sds.exportCsv", "when": "view == sdsExplorer && viewItem == sdsFile", "group": "2_export" },
        { "command": "arm-sds.deleteFile", "when": "view == sdsExplorer && viewItem == sdsFile", "group": "3_danger" }
      ],
      "explorer/context": [
        { "command": "arm-sds.openViewer", "when": "resourceExtname == .sds", "group": "navigation" },
        { "command": "arm-sds.openMediaViewer", "when": "resourceExtname == .sds", "group": "navigation" },
        { "command": "arm-sds.createMetadata", "when": "resourceExtname == .sds", "group": "navigation" }
      ],
      "commandPalette": [
        { "command": "arm-sds.deleteFile", "when": "false" }
      ]
    },
    "languages": [
      {
        "id": "sds-config",
        "aliases": ["SDS Configuration"],
        "extensions": [".sds.yml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "scripts": {
      "compile": "tsc -p .",
      "build": "node esbuild.js --production",
      "postbuild": "node scripts/copy-native-modules.js",
      "package": "npm run build && npm run postbuild && vsce package",
      "test:unit": "vitest run --config vitest.config.ts",
      "test:integration": "vitest run --config test/e2e/vitest.integration.config.ts",
      "test:e2e": "npx playwright test --config=playwright.config.ts --reporter=line"
    },
    "keybindings": [
      { "command": "arm-sds.openViewer", "key": "ctrl+shift+v", "mac": "cmd+shift+v", "when": "resourceExtname == .sds" },
      { "command": "arm-sds.openRecorder", "key": "ctrl+shift+r", "mac": "cmd+shift+r", "when": "sdsExplorer.active" },
      { "command": "arm-sds.quickOpen", "key": "ctrl+shift+s", "mac": "cmd+shift+s", "when": "workbenchState != empty" }
    ],
    "snippets": [
      { "language": "sds-config", "path": "./snippets/sds-metadata.json" },
      { "language": "yaml", "path": "./snippets/sds-metadata.json" }
    ]
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.js --production",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "test:e2e": "playwright test",
    "package": "vsce package --allow-missing-repository --baseContentUrl ."
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/vscode": "^1.108.1",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vscode/vsce": "^3.7.1",
    "@playwright/test": "^1.58.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "serialport": "^13.0.0",
    "usb": "^2.17.0"
  }
}
