{
    "name": "cmsis-sds",
    "displayName": "Arm CMSIS SDS",
    "description": "Record and manage synchronous data streams for ML/DSP development using the Arm SDS-Framework",
    "version": "0.8.0",
    "publisher": "arm",
    "license": "Apache-2.0",
    "engines": {
        "node": "^22.22.0",
        "npm": "^10.0.0",
        "vscode": "^1.108.1"
    },
    "categories": [
        "Visualization",
        "Other"
    ],
    "keywords": [
        "arm",
        "sds",
        "sensor",
        "iot",
        "cmsis",
        "data stream",
        "waveform"
    ],
    "icon": "media/icons/sds-icon.png",
    "activationEvents": [
        "onLanguage:yaml",
        "workspaceContains:**/*.sds",
        "workspaceContains:**/*.sds.yml",
        "workspaceContains:**/*.sdsio.yml"
    ],
    "qna": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds/issues/new",
    "bugs": {
        "url": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/Open-CMSIS-Pack/vscode-cmsis-sds.git"
    },
    "main": "./out/src/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "arm-sds.openViewer",
                "title": "Open SDS Viewer",
                "category": "SDS Tools",
                "icon": "$(graph-line)"
            },
            {
                "command": "arm-sds.openMediaViewer",
                "title": "Open Media Viewer",
                "category": "SDS Tools",
                "icon": "$(preview)"
            },
            {
                "command": "arm-sds.exportCsv",
                "title": "Export SDS to CSV",
                "category": "SDS Tools",
                "icon": "$(export)"
            },
            {
                "command": "arm-sds.refreshExplorer",
                "title": "Refresh SDS Explorer",
                "category": "SDS Tools",
                "icon": "$(refresh)"
            },
            {
                "command": "arm-sds.initWorkspace",
                "title": "Initialize SDS Workspace",
                "category": "SDS Tools",
                "icon": "$(folder-opened)"
            },
            {
                "command": "arm-sds.deleteFile",
                "title": "Delete SDS File",
                "category": "SDS Tools",
                "icon": "$(trash)"
            },
            {
                "command": "arm-sds.createMetadata",
                "title": "Create / Edit Metadata (YAML)",
                "category": "SDS Tools",
                "icon": "$(file-add)"
            },
            {
                "command": "arm-sds.showDiagnostics",
                "title": "Show Diagnostics",
                "category": "SDS Tools",
                "icon": "$(output)"
            },
            {
                "command": "arm-sds.clearDiagnostics",
                "title": "Clear Diagnostics Log",
                "category": "SDS Tools",
                "icon": "$(clear-all)"
            },
            {
                "command": "arm-sds.quickOpen",
                "title": "Quick Open SDS File",
                "category": "SDS Tools",
                "icon": "$(zap)"
            },
            {
                "command": "arm-sds.sdsinterface.play",
                "title": "Play Flags",
                "category": "SDS Tools",
                "icon": "$(play)",
                "enablement": "arm-sds.sdsio.canPlay"
            },
            {
                "command": "arm-sds.sdsinterface.record",
                "title": "Record Flags",
                "category": "SDS Tools",
                "icon": "$(record)",
                "enablement": "arm-sds.sdsio.canRecord"
            },
            {
                "command": "arm-sds.sdsinterface.stop",
                "title": "Stop Flags",
                "category": "SDS Tools",
                "icon": "$(debug-stop)",
                "enablement": "arm-sds.sdsio.canStop"
            },
            {
                "command": "arm-sds.sdsinterface.rename",
                "title": "Rename Flag",
                "category": "SDS Tools",
                "icon": "$(edit)"
            },
            {
                "command": "arm-sds.sdsinterface.connect",
                "title": "Connect SDSIO Monitor",
                "category": "SDS Tools",
                "icon": "$(plug)",
                "enablement": "arm-sds.sdsio.canConnect"
            },
            {
                "command": "arm-sds.sds.newConfig",
                "title": "New SDS Configuration",
                "category": "SDS",
                "icon": "$(add)"
            },
            {
                "command": "arm-sds.sds.openConfig",
                "title": "Open SDS Configuration",
                "category": "SDS",
                "icon": "$(folder-opened)"
            },
            {
                "command": "arm-sds.sds.selectConfig",
                "title": "Select Configuration File in Workspace",
                "category": "SDS"
            },
            {
                "command": "arm-sds.sds.editConfig",
                "title": "Edit Configuration",
                "category": "SDS",
                "icon": "$(file-code)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "arm-sds-explorer",
                    "title": "Arm CMSIS SDS",
                    "icon": "media/icons/sds-icon.svg"
                }
            ]
        },
        "views": {
            "arm-sds-explorer": [
                {
                    "id": "sdsExplorer",
                    "name": "SDS Files",
                    "icon": "$(graph-line)",
                    "contextualTitle": "SDS Explorer"
                },
                {
                    "id": "sdsIOInterface",
                    "name": "SDSIO Flags",
                    "icon": "$(symbol-boolean)",
                    "contextualTitle": "SDSIO Flags Interface"
                }
            ]
        },
        "viewsWelcome": [
            {
                "view": "sdsExplorer",
                "contents": "No SDS configuration selected.\n[New SDS Configuration](command:arm-sds.sds.newConfig)\n[Open SDS Configuration](command:arm-sds.sds.openConfig)"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "arm-sds.sdsinterface.connect",
                    "when": "view == sdsIOInterface && arm-sds.sdsio.canConnect",
                    "group": "navigation@0"
                },
                {
                    "command": "arm-sds.sdsinterface.play",
                    "when": "view == sdsExplorer",
                    "group": "navigation@1"
                },
                {
                    "command": "arm-sds.sdsinterface.record",
                    "when": "view == sdsExplorer",
                    "group": "navigation@2"
                },
                {
                    "command": "arm-sds.sdsinterface.stop",
                    "when": "view == sdsExplorer",
                    "group": "navigation@3"
                },
                {
                    "command": "arm-sds.refreshExplorer",
                    "when": "view == sdsExplorer",
                    "group": "navigation@4"
                },
                {
                    "command": "arm-sds.sds.editConfig",
                    "when": "view == sdsExplorer && arm-sds.sdsio.hasConfig",
                    "group": "navigation@5"
                },
                {
                    "command": "arm-sds.sds.selectConfig",
                    "when": "view == sdsExplorer",
                    "group": "1_config"
                },
                {
                    "command": "arm-sds.sds.newConfig",
                    "when": "view == sdsExplorer",
                    "group": "1_config"
                }
            ],
            "view/item/context": [
                {
                    "command": "arm-sds.openViewer",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "inline"
                },
                {
                    "command": "arm-sds.openMediaViewer",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "1_view"
                },
                {
                    "command": "arm-sds.createMetadata",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "1_view"
                },
                {
                    "command": "arm-sds.exportCsv",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "2_export"
                },
                {
                    "command": "arm-sds.deleteFile",
                    "when": "view == sdsExplorer && viewItem == sdsFile",
                    "group": "3_danger"
                },
                {
                    "command": "arm-sds.sdsinterface.rename",
                    "when": "view == sdsIOInterface && viewItem == sdsFlag",
                    "group": "inline"
                }
            ],
            "explorer/context": [
                {
                    "command": "arm-sds.openViewer",
                    "when": "resourceExtname == .sds",
                    "group": "navigation"
                },
                {
                    "command": "arm-sds.openMediaViewer",
                    "when": "resourceExtname == .sds",
                    "group": "navigation"
                },
                {
                    "command": "arm-sds.createMetadata",
                    "when": "resourceExtname == .sds",
                    "group": "navigation"
                }
            ],
            "commandPalette": [
                {
                    "command": "arm-sds.deleteFile",
                    "when": "false"
                }
            ]
        },
        "languages": [
            {
                "id": "sds-config",
                "aliases": [
                    "SDS Configuration"
                ],
                "extensions": [
                    ".sds.yml",
                    ".sdsio.yml"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "configuration": {
            "title": "SDS",
            "properties": {
                "arm-sds.viewer.defaultZoomLevel": {
                    "type": "number",
                    "default": 1,
                    "description": "Default zoom level for the waveform viewer"
                },
                "arm-sds.viewer.colorScheme": {
                    "type": "string",
                    "default": "auto",
                    "enum": [
                        "auto",
                        "dark",
                        "light"
                    ],
                    "description": "Color scheme for the waveform viewer"
                },
                "cmsis-sds.sdsio.configFile": {
                    "type": "string",
                    "default": "",
                    "description": "Relative path to the active .sdsio.yml configuration file"
                }
            }
        },
        "keybindings": [
            {
                "command": "arm-sds.openViewer",
                "key": "ctrl+shift+v",
                "mac": "cmd+shift+v",
                "when": "resourceExtname == .sds"
            },
            {
                "command": "arm-sds.quickOpen",
                "key": "ctrl+shift+s",
                "mac": "cmd+shift+s",
                "when": "workbenchState != empty"
            }
        ],
        "snippets": [
            {
                "language": "sds-config",
                "path": "./snippets/sds-metadata.json"
            },
            {
                "language": "yaml",
                "path": "./snippets/sds-metadata.json"
            }
        ],
        "icons": {
            "arm-sds-sds-icon": {
                "description": "CMSIS SDS — sds-icon",
                "default": {
                    "fontPath": "./media/cmsissds.ttf",
                    "fontCharacter": "\\E000"
                }
            }
        }
    },
    "scripts": {
        "build:icons": "fantasticon && node scripts/generate-icon-contributes.js",
        "compile": "npm-run-all compile:extension compile:webviews",
        "compile:extension": "tsc -p .",
        "compile:webviews": "node esbuild.js",
        "watch": "run-p watch:extension watch:webviews",
        "watch:extension": "tsc -watch -p .",
        "watch:webviews": "node esbuild.js --watch",
        "prebuild": "npm run build:icons",
        "build": "node esbuild.js --production",
        "postbuild": "node scripts/copy-native-modules.js",
        "package": "npm run build && npm run postbuild && vsce package",
        "lint:md": "markdownlint **/*.md -c ./.github/markdownlint.jsonc -i ./node_modules -i ./dist -i ./coverage -i ./out -i ./tools -i ./test-data -i ./src/e2e-tests/data -i CHANGELOG.md",
        "test": "npm-run-all test:unit test:integration test:e2e",
        "test:unit": "vitest run --config vitest.config.ts",
        "test:integration": "vitest run --config vitest.config.ts",
        "test:e2e": "npx playwright test --config=playwright.config.ts"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.0",
        "@twbs/fantasticon": "^3.1.0",
        "@types/node": "^22.19.15",
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@types/vscode": "^1.108.1",
        "@typescript-eslint/eslint-plugin": "8.56.1",
        "@typescript-eslint/parser": "8.56.1",
        "@vscode/vsce": "^3.7.1",
        "esbuild": "^0.27.3",
        "eslint": "^10.0.2",
        "markdownlint-cli": "^0.47.0",
        "npm-run-all": "^4.1.5",
        "typescript": "^5.9.3",
        "vitest": "^4.1.1"
    },
    "dependencies": {
        "@serialport/binding-mock": "^10.2.2",
        "@serialport/bindings-cpp": "^13.0.1",
        "@serialport/bindings-interface": "^1.2.2",
        "@serialport/parser-byte-length": "^13.0.0",
        "@serialport/parser-cctalk": "^13.0.0",
        "@serialport/parser-delimiter": "^13.0.0",
        "@serialport/parser-inter-byte-timeout": "^13.0.0",
        "@serialport/parser-packet-length": "^13.0.0",
        "@serialport/parser-readline": "^13.0.0",
        "@serialport/parser-ready": "^13.0.0",
        "@serialport/parser-regex": "^13.0.0",
        "@serialport/parser-slip-encoder": "^13.0.0",
        "@serialport/parser-spacepacket": "^13.0.0",
        "@serialport/stream": "^13.0.0",
        "antd": "^6.3.4",
        "debug": "^4.4.3",
        "ms": "^2.1.3",
        "node-gyp-build": "^4.8.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "serialport": "^13.0.0",
        "usb": "^2.17.0"
    },
    "overrides": {
        "@vscode/vsce": {
            "cheerio": "1.0.0-rc.12"
        },
        "markdownlint-cli": {
            "minimatch": "^10.2.4"
        }
    }
}
